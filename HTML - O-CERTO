<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema MEI - Gestão de Notas e Faturamento</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
        }

        /* Header */
        .header {
            background: white;
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo h1 {
            color: #333;
            font-size: 24px;
        }

        .logo span {
            color: #667eea;
            font-size: 14px;
            display: block;
        }

        .stats {
            display: flex;
            gap: 20px;
        }

        .stat-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 15px 25px;
            border-radius: 10px;
            text-align: center;
        }

        .stat-card h3 {
            font-size: 14px;
            opacity: 0.9;
        }

        .stat-card .value {
            font-size: 24px;
            font-weight: bold;
        }

        /* Main Grid */
        .main-grid {
            display: grid;
            grid-template-columns: 300px 1fr;
            gap: 20px;
        }

        /* Sidebar - Lista de MEIs */
        .mei-list {
            background: white;
            border-radius: 15px;
            padding: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            height: fit-content;
        }

        .mei-list h2 {
            color: #333;
            margin-bottom: 20px;
            font-size: 18px;
            border-bottom: 2px solid #f0f0f0;
            padding-bottom: 10px;
        }

        .add-mei-btn {
            width: 100%;
            padding: 12px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 16px;
            margin-bottom: 20px;
            transition: transform 0.3s;
        }

        .add-mei-btn:hover {
            transform: scale(1.02);
        }

        .mei-item {
            padding: 15px;
            border: 1px solid #f0f0f0;
            border-radius: 8px;
            margin-bottom: 10px;
            cursor: pointer;
            transition: all 0.3s;
        }

        .mei-item:hover {
            background: #f8f9fa;
            border-color: #667eea;
        }

        .mei-item.active {
            border: 2px solid #667eea;
            background: #f0f3ff;
        }

        .mei-item h3 {
            color: #333;
            font-size: 16px;
            margin-bottom: 5px;
        }

        .mei-item .cnpj {
            color: #666;
            font-size: 12px;
            margin-bottom: 10px;
        }

        .mei-item .faturamento {
            font-weight: bold;
            color: #28a745;
        }

        .mei-item .limite {
            font-size: 12px;
            color: #dc3545;
        }

        /* Main Content */
        .main-content {
            background: white;
            border-radius: 15px;
            padding: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }

        .content-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .content-header h2 {
            color: #333;
        }

        .add-note-btn {
            padding: 10px 20px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: transform 0.3s;
        }

        .add-note-btn:hover {
            transform: scale(1.02);
        }

        /* Tabs */
        .tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            border-bottom: 2px solid #f0f0f0;
            padding-bottom: 10px;
        }

        .tab {
            padding: 10px 20px;
            cursor: pointer;
            border-radius: 5px;
            transition: all 0.3s;
        }

        .tab.active {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        /* Tables */
        .table-container {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            background: #f8f9fa;
            padding: 12px;
            text-align: left;
            font-size: 14px;
            color: #555;
        }

        td {
            padding: 12px;
            border-bottom: 1px solid #f0f0f0;
        }

        .status-badge {
            padding: 5px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
        }

        .status-pago {
            background: #d4edda;
            color: #155724;
        }

        .status-pendente {
            background: #fff3cd;
            color: #856404;
        }

        .status-atrasado {
            background: #f8d7da;
            color: #721c24;
        }

        .actions {
            display: flex;
            gap: 10px;
        }

        .action-btn {
            padding: 5px 10px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 12px;
        }

        .edit-btn {
            background: #007bff;
            color: white;
        }

        .delete-btn {
            background: #dc3545;
            color: white;
        }

        /* Faturamento Cards */
        .faturamento-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 20px;
        }

        .card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px;
            border-radius: 10px;
            text-align: center;
        }

        .card h4 {
            font-size: 14px;
            margin-bottom: 10px;
            opacity: 0.9;
        }

        .card .valor {
            font-size: 24px;
            font-weight: bold;
        }

        /* Modal */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: white;
            padding: 30px;
            border-radius: 15px;
            width: 90%;
            max-width: 500px;
        }

        .modal-content h2 {
            margin-bottom: 20px;
            color: #333;
        }

        .form-group {
            margin-bottom: 15px;
        }

        .form-group label {
            display: block;
            margin-bottom: 5px;
            color: #555;
            font-size: 14px;
        }

        .form-group input,
        .form-group select {
            width: 100%;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 5px;
            font-size: 14px;
        }

        .modal-buttons {
            display: flex;
            gap: 10px;
            margin-top: 20px;
        }

        .modal-buttons button {
            flex: 1;
            padding: 12px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 14px;
        }

        .modal-buttons .save-btn {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .modal-buttons .cancel-btn {
            background: #6c757d;
            color: white;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .main-grid {
                grid-template-columns: 1fr;
            }
            
            .header {
                flex-direction: column;
                gap: 15px;
            }
            
            .stats {
                flex-wrap: wrap;
                justify-content: center;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <div class="header">
            <div class="logo">
                <h1>Sistema MEI Manager</h1>
                <span>Gestão de Notas e Faturamento</span>
            </div>
            <div class="stats">
                <div class="stat-card">
                    <h3>Total MEIs</h3>
                    <div class="value" id="total-meis">0</div>
                </div>
                <div class="stat-card">
                    <h3>Faturamento Mensal</h3>
                    <div class="value" id="faturamento-mensal">R$ 0</div>
                </div>
                <div class="stat-card">
                    <h3>Notas Emitidas</h3>
                    <div class="value" id="total-notas">0</div>
                </div>
            </div>
        </div>

        <!-- Main Grid -->
        <div class="main-grid">
            <!-- Sidebar - Lista de MEIs -->
            <div class="mei-list">
                <h2>MEIs Cadastrados</h2>
                <button class="add-mei-btn" onclick="abrirModalMEI()">+ Novo MEI</button>
                <div id="lista-meis">
                    <!-- MEIs serão inseridos aqui via JavaScript -->
                </div>
            </div>

            <!-- Main Content -->
            <div class="main-content">
                <div class="content-header">
                    <h2 id="mei-selecionado-nome">Selecione um MEI</h2>
                    <button class="add-note-btn" onclick="abrirModalNota()">+ Nova Nota</button>
                </div>

                <!-- Faturamento Cards -->
                <div class="faturamento-cards">
                    <div class="card">
                        <h4>Faturamento Mensal</h4>
                        <div class="valor" id="card-faturamento-mensal">R$ 0,00</div>
                    </div>
                    <div class="card">
                        <h4>Limite Disponível</h4>
                        <div class="valor" id="card-limite-disponivel">R$ 81.000,00</div>
                    </div>
                    <div class="card">
                        <h4>Total de Notas</h4>
                        <div class="valor" id="card-total-notas">0</div>
                    </div>
                </div>

                <!-- Tabs -->
                <div class="tabs">
                    <div class="tab active" onclick="mudarAba('notas')">Notas Fiscais</div>
                    <div class="tab" onclick="mudarAba('faturamento')">Histórico de Faturamento</div>
                </div>

                <!-- Conteúdo das Abas -->
                <div id="conteudo-notas">
                    <div class="table-container">
                        <table>
                            <thead>
                                <tr>
                                    <th>Número</th>
                                    <th>Data</th>
                                    <th>Cliente</th>
                                    <th>Valor</th>
                                    <th>Status</th>
                                    <th>Ações</th>
                                </tr>
                            </thead>
                            <tbody id="tabela-notas">
                                <!-- Notas serão inseridas aqui via JavaScript -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <div id="conteudo-faturamento" style="display: none;">
                    <div class="table-container">
                        <table>
                            <thead>
                                <tr>
                                    <th>Mês/Ano</th>
                                    <th>Faturamento</th>
                                    <th>Limite Utilizado</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody id="tabela-faturamento">
                                <!-- Histórico será inserido aqui via JavaScript -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal MEI -->
    <div class="modal" id="modal-mei">
        <div class="modal-content">
            <h2>Novo MEI</h2>
            <form id="form-mei">
                <div class="form-group">
                    <label>Nome Empresarial</label>
                    <input type="text" id="mei-nome" required>
                </div>
                <div class="form-group">
                    <label>CNPJ</label>
                    <input type="text" id="mei-cnpj" placeholder="00.000.000/0000-00" required>
                </div>
                <div class="form-group">
                    <label>Nome do Titular</label>
                    <input type="text" id="mei-titular" required>
                </div>
                <div class="form-group">
                    <label>Atividade Principal</label>
                    <input type="text" id="mei-atividade" required>
                </div>
                <div class="modal-buttons">
                    <button type="button" class="cancel-btn" onclick="fecharModalMEI()">Cancelar</button>
                    <button type="submit" class="save-btn">Salvar</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal Nota -->
    <div class="modal" id="modal-nota">
        <div class="modal-content">
            <h2>Nova Nota Fiscal</h2>
            <form id="form-nota">
                <div class="form-group">
                    <label>Número da Nota</label>
                    <input type="text" id="nota-numero" required>
                </div>
                <div class="form-group">
                    <label>Data</label>
                    <input type="date" id="nota-data" required>
                </div>
                <div class="form-group">
                    <label>Cliente</label>
                    <input type="text" id="nota-cliente" required>
                </div>
                <div class="form-group">
                    <label>Valor (R$)</label>
                    <input type="number" id="nota-valor" step="0.01" required>
                </div>
                <div class="form-group">
                    <label>Status</label>
                    <select id="nota-status">
                        <option value="Pago">Pago</option>
                        <option value="Pendente">Pendente</option>
                        <option value="Atrasado">Atrasado</option>
                    </select>
                </div>
                <div class="modal-buttons">
                    <button type="button" class="cancel-btn" onclick="fecharModalNota()">Cancelar</button>
                    <button type="submit" class="save-btn">Salvar</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        // Dados da aplicação
        let meis = [];
        let notas = [];
        let meiSelecionado = null;
        let abaAtiva = 'notas';

        // Carregar dados iniciais
        function carregarDadosIniciais() {
            // MEIs de exemplo
            meis = [
                {
                    id: 1,
                    nome: 'Tech Solutions MEI',
                    cnpj: '12.345.678/0001-90',
                    titular: 'João Silva',
                    atividade: 'Desenvolvimento de Software',
                    faturamentoMensal: 5000,
                    limiteAnual: 81000
                },
                {
                    id: 2,
                    nome: 'Comercial Express',
                    cnpj: '98.765.432/0001-10',
                    titular: 'Maria Santos',
                    atividade: 'Comércio Varejista',
                    faturamentoMensal: 3500,
                    limiteAnual: 81000
                }
            ];

            // Notas de exemplo
            notas = [
                {
                    id: 1,
                    meiId: 1,
                    numero: 'NF-001',
                    data: '2024-01-15',
                    cliente: 'Empresa ABC',
                    valor: 1500,
                    status: 'Pago'
                },
                {
                    id: 2,
                    meiId: 1,
                    numero: 'NF-002',
                    data: '2024-01-20',
                    cliente: 'Cliente XYZ',
                    valor: 2000,
                    status: 'Pendente'
                },
                {
                    id: 3,
                    meiId: 2,
                    numero: 'NF-001',
                    data: '2024-01-10',
                    cliente: 'Loja Centro',
                    valor: 800,
                    status: 'Pago'
                }
            ];

            atualizarInterface();
        }

        // Atualizar interface
        function atualizarInterface() {
            atualizarStats();
            renderizarListaMEIs();
            if (meiSelecionado) {
                renderizarConteudoMEI();
            }
        }

        // Atualizar estatísticas
        function atualizarStats() {
            document.getElementById('total-meis').textContent = meis.length;
            
            let totalFaturamento = 0;
            let totalNotas = 0;
            
            if (meiSelecionado) {
                const notasMEI = notas.filter(n => n.meiId === meiSelecionado.id);
                totalFaturamento = notasMEI.reduce((sum, n) => sum + n.valor, 0);
                totalNotas = notasMEI.length;
            } else {
                totalFaturamento = notas.reduce((sum, n) => sum + n.valor, 0);
                totalNotas = notas.length;
            }
            
            document.getElementById('faturamento-mensal').textContent = 
                `R$ ${totalFaturamento.toFixed(2)}`;
            document.getElementById('total-notas').textContent = totalNotas;
        }

        // Renderizar lista de MEIs
        function renderizarListaMEIs() {
            const container = document.getElementById('lista-meis');
            container.innerHTML = '';

            meis.forEach(mei => {
                const notasMEI = notas.filter(n => n.meiId === mei.id);
                const faturamentoTotal = notasMEI.reduce((sum, n) => sum + n.valor, 0);
                const limiteUtilizado = (faturamentoTotal / mei.limiteAnual * 100).toFixed(1);

                const meiItem = document.createElement('div');
                meiItem.className = `mei-item ${meiSelecionado && meiSelecionado.id === mei.id ? 'active' : ''}`;
                meiItem.onclick = () => selecionarMEI(mei.id);
                meiItem.innerHTML = `
                    <h3>${mei.nome}</h3>
                    <div class="cnpj">${mei.cnpj}</div>
                    <div class="faturamento">R$ ${faturamentoTotal.toFixed(2)}</div>
                    <div class="limite">Limite: ${limiteUtilizado}% utilizado</div>
                `;
                container.appendChild(meiItem);
            });
        }

        // Selecionar MEI
        function selecionarMEI(id) {
            meiSelecionado = meis.find(m => m.id === id);
            document.getElementById('mei-selecionado-nome').textContent = 
                meiSelecionado ? meiSelecionado.nome : 'Selecione um MEI';
            renderizarConteudoMEI();
            atualizarStats();
            renderizarListaMEIs();
        }

        // Renderizar conteúdo do MEI selecionado
        function renderizarConteudoMEI() {
            if (!meiSelecionado) return;

            const notasMEI = notas.filter(n => n.meiId === meiSelecionado.id);
            const faturamentoTotal = notasMEI.reduce((sum, n) => sum + n.valor, 0);
            const limiteDisponivel = meiSelecionado.limiteAnual - faturamentoTotal;

            document.getElementById('card-faturamento-mensal').textContent = 
                `R$ ${faturamentoTotal.toFixed(2)}`;
            document.getElementById('card-limite-disponivel').textContent = 
                `R$ ${limiteDisponivel.toFixed(2)}`;
            document.getElementById('card-total-notas').textContent = notasMEI.length;

            if (abaAtiva === 'notas') {
                renderizarTabelaNotas(notasMEI);
            } else {
                renderizarTabelaFaturamento();
            }
        }

        // Renderizar tabela de notas
        function renderizarTabelaNotas(notasMEI) {
            const tbody = document.getElementById('tabela-notas');
            tbody.innerHTML = '';

            if (notasMEI.length === 0) {
                tbody.innerHTML = '<tr><td colspan="6" style="text-align: center;">Nenhuma nota encontrada</td></tr>';
                return;
            }

            notasMEI.forEach(nota => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td>${nota.numero}</td>
                    <td>${new Date(nota.data).toLocaleDateString('pt-BR')}</td>
                    <td>${nota.cliente}</td>
                    <td>R$ ${nota.valor.toFixed(2)}</td>
                    <td><span class="status-badge status-${nota.status.toLowerCase()}">${nota.status}</span></td>
                    <td class="actions">
                        <button class="action-btn edit-btn" onclick="editarNota(${nota.id})">Editar</button>
                        <button class="action-btn delete-btn" onclick="excluirNota(${nota.id})">Excluir</button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        // Renderizar tabela de faturamento
        function renderizarTabelaFaturamento() {
            const tbody = document.getElementById('tabela-faturamento');
            tbody.innerHTML = '';

            const meses = [
                { mes: 'Janeiro/2024', valor: 3500, status: 'Dentro do Limite' },
                { mes: 'Fevereiro/2024', valor: 4200, status: 'Dentro do Limite' },
                { mes: 'Março/2024', valor: 3800, status: 'Dentro do Limite' }
            ];

            meses.forEach(mes => {
                const percentual = (mes.valor / 81000 * 100).toFixed(1);
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td>${mes.mes}</td>
                    <td>R$ ${mes.valor.toFixed(2)}</td>
                    <td>${percentual}%</td>
                    <td><span class="status-badge status-pago">${mes.status}</span></td>
                `;
                tbody.appendChild(tr);
            });
        }

        // Mudar aba
        function mudarAba(aba) {
            abaAtiva = aba;
            
            document.querySelectorAll('.tab').forEach(tab => {
                tab.classList.remove('active');
            });
            event.target.classList.add('active');

            document.getElementById('conteudo-notas').style.display = 
                aba === 'notas' ? 'block' : 'none';
            document.getElementById('conteudo-faturamento').style.display = 
                aba === 'faturamento' ? 'block' : 'none';

            if (meiSelecionado) {
                renderizarConteudoMEI();
            }
        }

        // Modal MEI
        function abrirModalMEI() {
            document.getElementById('modal-mei').classList.add('active');
        }

        function fecharModalMEI() {
            document.getElementById('modal-mei').classList.remove('active');
            document.getElementById('form-mei').reset();
        }

        // Modal Nota
        function abrirModalNota() {
            if (!meiSelecionado) {
                alert('Selecione um MEI primeiro!');
                return;
            }
            document.getElementById('modal-nota').classList.add('active');
        }

        function fecharModalNota() {
            document.getElementById('modal-nota').classList.remove('active');
            document.getElementById('form-nota').reset();
        }

        // Event Listeners
        document.getElementById('form-mei').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const novoMEI = {
                id: meis.length + 1,
                nome: document.getElementById('mei-nome').value,
                cnpj: document.getElementById('mei-cnpj').value,
                titular: document.getElementById('mei-titular').value,
                atividade: document.getElementById('mei-atividade').value,
                faturamentoMensal: 0,
                limiteAnual: 81000
            };

            meis.push(novoMEI);
            fecharModalMEI();
            atualizarInterface();
            alert('MEI cadastrado com sucesso!');
        });

        document.getElementById('form-nota').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const novaNota = {
                id: notas.length + 1,
                meiId: meiSelecionado.id,
                numero: document.getElementById('nota-numero').value,
                data: document.getElementById('nota-data').value,
                cliente: document.getElementById('nota-cliente').value,
                valor: parseFloat(document.getElementById('nota-valor').value),
                status: document.getElementById('nota-status').value
            };

            notas.push(novaNota);
            fecharModalNota();
            atualizarInterface();
            alert('Nota fiscal cadastrada com sucesso!');
        });

        // Funções de ação
        function editarNota(id) {
            alert('Função de edição em desenvolvimento');
        }

        function excluirNota(id) {
            if (confirm('Deseja realmente excluir esta nota?')) {
                notas = notas.filter(n => n.id !== id);
                atualizarInterface();
            }
        }

        // Inicializar
        carregarDadosIniciais();
    </script>
